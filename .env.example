# Copy this file to .env and fill in the values. Never commit .env.
# Keep notes on their own lines, the parser reads plain KEY=VALUE only.

# Create a free API key at https://resend.com under Dashboard > API Keys (free tier: 100 emails/day)
RESEND_API_KEY=

# The inbox that receives the report. On Resend's default onboarding sender this must be the email you signed up to Resend with; verify your own domain to send anywhere.
EMAIL_TO=

# Optional. Defaults to "AI Premarket Analyst <onboarding@resend.dev>". Set this once you verify your own domain in Resend.
# EMAIL_FROM=AI Premarket Analyst <reports@yourdomain.com>

# Telegram push for the Forward Radar summary (notify_radar.py). Create a bot with @BotFather to get the token.
TELEGRAM_BOT_TOKEN=

# Message your bot once, then read the chat id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=
